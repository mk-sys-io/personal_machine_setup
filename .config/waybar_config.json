{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["custom/volume", "custom/brightness", "custom/network", "keyboard-state", "battery"],

    "clock": {
        "format": "{:%d %b %H:%M}",
        "tooltip": false
    },

    "custom/network": {
        "exec": "~/.config/waybar/scripts/network.sh",
        "interval": 5,
        "return-type": "json",
        "tooltip": false
    },

    "custom/volume": {
        "exec": "~/.config/waybar/scripts/volume.sh",
        "interval": 1,
        "signal": 2,
        "return-type": "json",
        "tooltip": false
    },

    "custom/brightness": {
        "exec": "~/.config/waybar/scripts/brightness.sh",
        "interval": 1,
        "signal": 3,
        "return-type": "json",
        "tooltip": false
    },

    "keyboard-state": {
        "numlock": true,
        "format": "{icon}",
        "format-icons": {
            "locked": "NUM",
            "unlocked": "num"
        }
    },

    "battery": {
        "bat": "BAT0",
        "adapter": "AC",
        "full-at": 99,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT {capacity}%",
        "format-charging": "CHR {capacity}%",
        "format-plugged": "FUL {capacity}%",
        "tooltip": false
    }
}
