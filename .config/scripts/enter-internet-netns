#!/bin/bash
# enter-internet-netns — run a pre-approved command inside the internet namespace
# Usage: enter-internet-netns <command> [args...]
set -euo pipefail

if [ -z "${SUDO_USER:-}" ]; then
    echo "Error: enter-internet-netns must be run via sudo" >&2
    exit 1
fi

if [ $# -lt 1 ]; then
    echo "Error: Usage: enter-internet-netns <command> [args...]" >&2
    exit 1
fi

CMD=$(readlink -f "$1" 2>/dev/null || command -v "$1" 2>/dev/null || echo "$1")

case "$CMD" in
    /home/mike/.opencode/bin/opencode)
        logger -t internet-netns "OK: $SUDO_USER $*"
        exec ip netns exec internet-netns sudo -u "$SUDO_USER" "$@"
        ;;

    /usr/bin/podman)
        if [ "${2:-}" != "pull" ]; then
            echo "Error: Only 'podman pull' allowed in internet-netns" >&2
            logger -t internet-netns "DENY: $SUDO_USER podman ${2:-}"
            exit 1
        fi
        logger -t internet-netns "OK: $SUDO_USER $*"
        exec ip netns exec internet-netns sudo -u "$SUDO_USER" "$@"
        ;;

    *)
        echo "Error: Command not permitted in internet-netns" >&2
        echo "Allowed commands:" >&2
        echo "  /home/mike/.opencode/bin/opencode" >&2
        echo "  /usr/bin/podman pull" >&2
        logger -t internet-netns "DENY: $SUDO_USER $*"
        exit 1
        ;;
esac
