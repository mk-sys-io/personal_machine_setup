# mike — restricted tools only (no full sudo)
# Installed by linux_setup/install.sh
# See docs/root_ownership_inventory.md for the full lockdown architecture

# System updates
mike ALL=(root) NOPASSWD: /usr/bin/apt update
mike ALL=(root) NOPASSWD: /usr/bin/apt upgrade
mike ALL=(root) NOPASSWD: /usr/bin/apt install --reinstall *

# Service status (read-only — no start/stop/restart)
mike ALL=(root) NOPASSWD: /usr/bin/systemctl status *
mike ALL=(root) NOPASSWD: /usr/bin/systemctl is-active *
mike ALL=(root) NOPASSWD: /usr/bin/systemctl is-enabled *
mike ALL=(root) NOPASSWD: /usr/bin/systemctl list-units *

# Logs
mike ALL=(root) NOPASSWD: /usr/bin/journalctl *

# System control (reboot/poweroff/suspend)
mike ALL=(root) NOPASSWD: /usr/bin/systemctl reboot
mike ALL=(root) NOPASSWD: /sbin/reboot
mike ALL=(root) NOPASSWD: /usr/bin/systemctl poweroff
mike ALL=(root) NOPASSWD: /usr/bin/systemctl suspend

# Network service recovery (seal/unseal/sem WiFi dependency)
mike ALL=(root) NOPASSWD: /usr/bin/systemctl restart NetworkManager
mike ALL=(root) NOPASSWD: /usr/bin/systemctl restart dnsmasq
mike ALL=(root) NOPASSWD: /usr/bin/systemctl restart nftables

# Interface recovery (WiFi stuck after suspend/AX201 crash)
mike ALL=(root) NOPASSWD: /usr/sbin/ip link set *

# Firewall inspection (read-only — diagnose blocked recovery traffic)
mike ALL=(root) NOPASSWD: /usr/sbin/nft list *

# WiFi radio kill-switch (unblock after soft-block)
mike ALL=(root) NOPASSWD: /usr/sbin/rfkill

# Kernel log (WiFi/driver firmware errors per troubleshooting.md)
mike ALL=(root) NOPASSWD: /usr/bin/dmesg

# Timeshift system backup
mike ALL=(root) NOPASSWD: /usr/bin/timeshift
# Immutable flag for sealed credentials (timelock protection)
mike ALL=(root) NOPASSWD: /usr/bin/chattr

# Clipboard tools — run as self to clear history under Wayland
mike ALL=(mike) NOPASSWD: /usr/bin/wl-copy
mike ALL=(mike) NOPASSWD: /usr/bin/copyq

# Internet network namespace — run approved commands with unrestricted internet
# Command allowlist enforced by the wrapper script, not by sudoers granularity
mike ALL=(root) NOPASSWD: /usr/local/bin/enter-internet-netns *
