# sway config

### Variables
set $mod Mod4
set $term kitty
set $config_dir ~/.config/sway
set $menu rofi -show drun -config $config_dir/rofi/config.rasi

### Output configuration
#
# Desktop wallpaper. This line sets the background image for all outputs.
#
# Fallback: if the file is missing (e.g. fresh install before wallpapers are
# added), sway shows a solid black background. No errors, no crash — just black.
#
# Theme switcher (Super+Shift+T) patches this line automatically when you
# switch themes. Each theme's theme.conf specifies its own wallpaper filename.
#
# To manually set a wallpaper:
#   1. Place the image in ~/.config/sway/wallpaper/
#   2. Update the filename in this line to match
#   3. Run: swaymsg reload
#
# To set a per-theme wallpaper:
#   1. Edit ~/.config/sway/themes/<theme>/theme.conf
#   2. Change the wallpaper = value to your filename
#   3. Switch to that theme with Super+Shift+T — it patches this line for you
#
output * bg $config_dir/wallpaper/wp4676582-4k-pc-wallpapers.jpg fill

# For multiple monitors:
# output HDMI-A-1 resolution 1920x1080 position 1920,0

# HiDPI / 4K: sway defaults to scale 1, so type is tiny on a 4K screen.
# Uncomment to scale the whole display — fonts, bar, cursor, and XWayland
# apps all follow it. Fractional values like 1.5 work too (unlike X11).
# output * scale 2

### Idle configuration
exec swayidle -w \
    timeout 120  'brightnessctl set 30%' \
                   resume 'brightnessctl set 100%' \
    timeout 300  'gtklock' \
    timeout 600  'swaymsg "output * dpms off"' \
                   resume 'swaymsg "output * dpms on"' \
    before-sleep 'gtklock' \
    after-resume 'swaymsg "output * enable"'

### Input configuration
input type:touchpad {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
}

input type:keyboard {
    xkb_layout "fr"
    xkb_numlock enabled
    repeat_delay 300
    repeat_rate 50
}

exec_always numlockwl --on

### Appearance
font pango:Lilex Nerd Font Mono 11

# Colors (theme-swappable via current-theme symlink)
include $config_dir/current-theme/colors.conf

# class                 border   backgr  text    indicator child_border
client.focused          $barbie  $cyan   $gray   $blue     $barbie
client.focused_inactive $gray    $bg     $fg     $bg       $gray
client.unfocused        $gray    $bg     $fg     $bg       $gray
client.urgent           $blue    $blue   $bg     $blue     $blue

### Includes
include $config_dir/workspaces.conf
include $config_dir/rules.conf
include $config_dir/keybindings.conf

### Autostart
exec_always $config_dir/scripts/autostart.sh

#include /etc/sway/config.d/*
