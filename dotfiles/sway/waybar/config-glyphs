{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 0,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,

    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock#date", "custom/sep", "clock#time"],
    "modules-right": ["custom/menu", "custom/sep", "custom/hwmon", "custom/sep", "pulseaudio", "custom/sep", "backlight", "custom/sep", "network", "custom/sep", "battery", "custom/sep", "custom/numlock", "custom/notification", "tray"],

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": [],
            "7": []
        }
    },

    "custom/sep": {
        "format": "|",
        "tooltip": false
    },

    "tray": {
        "spacing": 4
    },

    "clock#date": {
        "format": "{:%a %b %d}",
        "tooltip": false
    },

    "clock#time": {
        "format": "{:%I:%M %p}",
        "format-alt": "{:%Y-%m-%d %I:%M:%S %p}",
        "tooltip-format": "<b>{:%A, %B %d, %Y}</b>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#d0d7de'><b>{}</b></span>",
                "days": "<span color='#d0d7de'>{}</span>",
                "weekdays": "<span color='#D29922'><b>{}</b></span>",
                "today": "<span color='#539bf5'><b><u>{}</u></b></span>"
            }
        }
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "interval": 1,
        "format": "{icon} {capacity}%",
        "format-charging": "蟀倓 {capacity}%",
        "format-plugged": "蟀殽 {capacity}%",
        "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"],
        "tooltip-format": "{capacity}% | Health: {health}"
    },

    "network": {
        "format-wifi": "蟀え {essid}",
        "format-ethernet": "蟀垁 {ipaddr}",
        "format-disconnected": "蟀き disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "~/.config/waybar/scripts/toggle-nmtui.sh",
        "interval": 5
    },

    "pulseaudio": {
        "format": "<span color='#D29922'>蟀暰</span> {volume}%",
        "format-muted": "蟀杹 muted",
        "tooltip": false,
        "on-click": "pavucontrol"
    },

    "backlight": {
        "format": "<span color='#D29922'>{icon}</span> {percent}%",
        "format-icons": ["蟀優", "蟀儫", "蟀儬"],
        "tooltip": false
    },

    "custom/numlock": {
        "exec": "~/.config/waybar/scripts/numlock.sh",
        "return-type": "json",
        "interval": 1,
        "tooltip": false
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "<span foreground='#D29922'>蟀倸</span>",
            "none": "<span foreground='#d0d7de'>蟀倸</span>",
            "dnd-notification": "<span foreground='#D29922'>蟀倹</span>",
            "dnd-none": "<span foreground='#d0d7de'>蟀倹</span>",
            "inhibited-notification": "<span foreground='#D29922'>蟀倸</span>",
            "inhibited-none": "<span foreground='#d0d7de'>蟀倸</span>",
            "dnd-inhibited-notification": "<span foreground='#D29922'>蟀倹</span>",
            "dnd-inhibited-none": "<span foreground='#d0d7de'>蟀倹</span>"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb --skip-wait",
        "on-click": "swaync-client -t",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "restart-interval": 3
    },

    "custom/menu": {
        "exec": "~/.config/waybar/scripts/bluetooth-status.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{text}",
        "tooltip": true,
        "on-click": "~/.config/waybar/scripts/system-menu.sh"
    },

    "custom/hwmon": {
        "exec": "~/.config/waybar/scripts/hwmon.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{text}",
        "tooltip": true
    }
}
